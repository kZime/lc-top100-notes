{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "C++: run active file",
            "type": "cppdbg",
            "request": "launch",
            "program": "${workspaceFolder}/.vscode/bin/${relativeFileDirname}/${fileBasenameNoExtension}.run.bin",
            "args": [],
            "stopAtEntry": false,
            "cwd": "${fileDirname}",
            "environment": [],
            "externalConsole": false,
            "preLaunchTask": "C++: build active file (run)",
            "noDebug": true,
            "MIMode": "gdb",
            "miDebuggerPath": "/usr/bin/gdb",
            "setupCommands": [
                {
                    "description": "Enable pretty-printing for gdb",
                    "text": "-enable-pretty-printing",
                    "ignoreFailures": true
                }
            ]
        },
        {
            "name": "C++: debug active file",
            "type": "cppdbg",
            "request": "launch",
            "program": "${workspaceFolder}/.vscode/bin/${relativeFileDirname}/${fileBasenameNoExtension}.debug.bin",
            "args": [],
            "stopAtEntry": false,
            "cwd": "${fileDirname}",
            "environment": [],
            "externalConsole": false,
            "preLaunchTask": "C++: build active file (debug)",
            "MIMode": "gdb",
            "miDebuggerPath": "/usr/bin/gdb",
            "setupCommands": [
                {
                    "description": "Enable pretty-printing for gdb",
                    "text": "-enable-pretty-printing",
                    "ignoreFailures": true
                }
            ]
        }
    ]
}