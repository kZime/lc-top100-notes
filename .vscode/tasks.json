{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "C++: build active file (run)",
            "type": "shell",
            "command": "/bin/bash",
            "args": [
                "-lc",
                "mkdir -p \"${workspaceFolder}/.vscode/bin/${relativeFileDirname}\" && /usr/bin/g++ -std=c++20 -O2 -DNDEBUG -Wall -Wextra -Wpedantic -fdiagnostics-color=always \"${file}\" -o \"${workspaceFolder}/.vscode/bin/${relativeFileDirname}/${fileBasenameNoExtension}.run.bin\""
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "problemMatcher": [
                "$gcc"
            ],
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": false,
                "panel": "shared",
                "clear": true
            },
            "detail": "Build the active C++ file for running."
        },
        {
            "label": "C++: build active file (debug)",
            "type": "shell",
            "command": "/bin/bash",
            "args": [
                "-lc",
                "mkdir -p \"${workspaceFolder}/.vscode/bin/${relativeFileDirname}\" && /usr/bin/g++ -std=c++20 -g3 -O0 -fno-omit-frame-pointer -Wall -Wextra -Wpedantic -fdiagnostics-color=always \"${file}\" -o \"${workspaceFolder}/.vscode/bin/${relativeFileDirname}/${fileBasenameNoExtension}.debug.bin\""
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "problemMatcher": [
                "$gcc"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": false,
                "panel": "shared",
                "clear": true
            },
            "detail": "Build the active C++ file for debugging."
        },
        {
            "label": "C++: run active file",
            "type": "shell",
            "command": "/bin/bash",
            "args": [
                "-lc",
                "\"${workspaceFolder}/.vscode/bin/${relativeFileDirname}/${fileBasenameNoExtension}.run.bin\""
            ],
            "options": {
                "cwd": "${fileDirname}"
            },
            "dependsOn": "C++: build active file (run)",
            "dependsOrder": "sequence",
            "problemMatcher": [],
            "group": {
                "kind": "test",
                "isDefault": true
            },
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": true,
                "panel": "shared",
                "clear": false
            },
            "detail": "Build first, then run the active C++ file in the integrated terminal."
        }
    ]
}
