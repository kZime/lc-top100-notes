---
Language: Cpp
BasedOnStyle: Google
Standard: c++17

# --- Indentation ---
IndentWidth: 4
ContinuationIndentWidth: 4
UseTab: Never
AccessModifierOffset: -4        # public/private 与 class 对齐，不缩进

# --- Line length ---
ColumnLimit: 100

# --- Braces ---
BreakBeforeBraces: Attach       # K&R 风格：左括号不换行
InsertBraces: true              # 强制 if/for/while 加大括号（clang-format 14+）

# --- Short statements：全部展开，避免把逻辑压缩成一行 ---
AllowShortBlocksOnASingleLine: Empty
AllowShortCaseLabelsOnASingleLine: false
AllowShortFunctionsOnASingleLine: Inline   # 只允许空函数体 {} 单行
AllowShortIfStatementsOnASingleLine: Never
AllowShortLoopsOnASingleLine: false
AllowShortLambdasOnASingleLine: Inline

# --- Pointers & references ---
PointerAlignment: Left          # int* p，而非 int *p

# --- Spacing ---
SpaceAfterCStyleCast: true
SpaceBeforeParens: ControlStatements
SpacesInAngles: Never
SpacesInContainerLiterals: false

# --- Includes ---
SortIncludes: Never             # 保持 #include <bits/stdc++.h> 在首位

# --- Constructor initializers ---
BreakConstructorInitializers: BeforeColon
ConstructorInitializerIndentWidth: 4
PackConstructorInitializers: Never

# --- Templates ---
AlwaysBreakTemplateDeclarations: Yes

# --- Alignment ---
AlignConsecutiveAssignments: false   # 对齐 = 会随改动大面积 diff，关掉
AlignConsecutiveDeclarations: false
AlignTrailingComments:
  Kind: Always
  OverEmptyLines: 0

# --- Trailing comma ---
InsertTrailingCommas: None
